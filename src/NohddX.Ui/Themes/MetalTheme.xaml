<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         NoHddX DARK METALLIC / BRUSHED STEEL THEME
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- ──────────────────────────────────────────────
         COLOR PALETTE - Dark Steel
         ────────────────────────────────────────────── -->
    <Color x:Key="MetalDarkest">#FF0D1117</Color>
    <Color x:Key="MetalDark">#FF161B22</Color>
    <Color x:Key="MetalMedium">#FF21262D</Color>
    <Color x:Key="MetalLight">#FF30363D</Color>
    <Color x:Key="MetalLighter">#FF484F58</Color>
    <Color x:Key="MetalBorder">#FF3D444D</Color>

    <!-- Chrome / Steel Highlights -->
    <Color x:Key="ChromeLight">#FFB0B8C4</Color>
    <Color x:Key="ChromeBright">#FFDCE0E5</Color>
    <Color x:Key="ChromeWhite">#FFF0F3F6</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentBlue">#FF58A6FF</Color>
    <Color x:Key="AccentGreen">#FF3FB950</Color>
    <Color x:Key="AccentAmber">#FFD29922</Color>
    <Color x:Key="AccentRed">#FFF85149</Color>
    <Color x:Key="AccentPurple">#FFBC8CFF</Color>

    <!-- ──────────────────────────────────────────────
         SOLID COLOR BRUSHES
         ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="MetalDarkestBrush"   Color="{StaticResource MetalDarkest}"/>
    <SolidColorBrush x:Key="MetalDarkBrush"       Color="{StaticResource MetalDark}"/>
    <SolidColorBrush x:Key="MetalMediumBrush"     Color="{StaticResource MetalMedium}"/>
    <SolidColorBrush x:Key="MetalLightBrush"      Color="{StaticResource MetalLight}"/>
    <SolidColorBrush x:Key="MetalLighterBrush"    Color="{StaticResource MetalLighter}"/>
    <SolidColorBrush x:Key="MetalBorderBrush"     Color="{StaticResource MetalBorder}"/>

    <SolidColorBrush x:Key="ChromeLightBrush"     Color="{StaticResource ChromeLight}"/>
    <SolidColorBrush x:Key="ChromeBrightBrush"    Color="{StaticResource ChromeBright}"/>
    <SolidColorBrush x:Key="ChromeWhiteBrush"     Color="{StaticResource ChromeWhite}"/>

    <SolidColorBrush x:Key="AccentBlueBrush"      Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"     Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentAmberBrush"     Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="AccentRedBrush"       Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush"    Color="{StaticResource AccentPurple}"/>

    <!-- ──────────────────────────────────────────────
         GRADIENT BRUSHES - Metal Effects
         ────────────────────────────────────────────── -->

    <!-- Brushed metal - subtle horizontal banding for realism -->
    <LinearGradientBrush x:Key="BrushedMetalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1C2128" Offset="0"/>
        <GradientStop Color="#FF252C35" Offset="0.15"/>
        <GradientStop Color="#FF1E242B" Offset="0.3"/>
        <GradientStop Color="#FF272E37" Offset="0.5"/>
        <GradientStop Color="#FF1C2128" Offset="0.7"/>
        <GradientStop Color="#FF242B34" Offset="0.85"/>
        <GradientStop Color="#FF1A2029" Offset="1"/>
    </LinearGradientBrush>

    <!-- Panel background with 3D raised bevel -->
    <LinearGradientBrush x:Key="MetalPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF2D333B" Offset="0"/>
        <GradientStop Color="#FF22272E" Offset="0.05"/>
        <GradientStop Color="#FF1C2128" Offset="0.95"/>
        <GradientStop Color="#FF161B22" Offset="1"/>
    </LinearGradientBrush>

    <!-- Header bar gradient -->
    <LinearGradientBrush x:Key="MetalHeaderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF30363D" Offset="0"/>
        <GradientStop Color="#FF21262D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card / tile background -->
    <LinearGradientBrush x:Key="MetalCardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF272E37" Offset="0"/>
        <GradientStop Color="#FF1C2128" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sidebar gradient (left-to-right) -->
    <LinearGradientBrush x:Key="MetalSidebarBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF161B22" Offset="0"/>
        <GradientStop Color="#FF1A2029" Offset="0.95"/>
        <GradientStop Color="#FF21262D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button gradient - resting state -->
    <LinearGradientBrush x:Key="MetalButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF30363D" Offset="0"/>
        <GradientStop Color="#FF21262D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button gradient - hover -->
    <LinearGradientBrush x:Key="MetalButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF3D444D" Offset="0"/>
        <GradientStop Color="#FF2D333B" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button gradient - pressed -->
    <LinearGradientBrush x:Key="MetalButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1C2128" Offset="0"/>
        <GradientStop Color="#FF161B22" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent button gradient -->
    <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF388BFD" Offset="0"/>
        <GradientStop Color="#FF1F6FEB" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF58A6FF" Offset="0"/>
        <GradientStop Color="#FF388BFD" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1A5EC8" Offset="0"/>
        <GradientStop Color="#FF1558B0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Danger button gradient -->
    <LinearGradientBrush x:Key="DangerButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFD73A49" Offset="0"/>
        <GradientStop Color="#FFB62324" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF85149" Offset="0"/>
        <GradientStop Color="#FFD73A49" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF9E1C1C" Offset="0"/>
        <GradientStop Color="#FF8B1A1A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Status bar groove -->
    <LinearGradientBrush x:Key="StatusBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0D1117" Offset="0"/>
        <GradientStop Color="#FF161B22" Offset="0.4"/>
        <GradientStop Color="#FF161B22" Offset="1"/>
    </LinearGradientBrush>

    <!-- ──────────────────────────────────────────────
         TYPOGRAPHY
         ────────────────────────────────────────────── -->
    <FontFamily x:Key="UIFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>

    <!-- ──────────────────────────────────────────────
         DROP SHADOW EFFECTS
         ────────────────────────────────────────────── -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2"
                      Direction="270" Color="#80000000" Opacity="0.5"/>
    <DropShadowEffect x:Key="SubtleShadow" BlurRadius="6" ShadowDepth="1"
                      Direction="270" Color="#60000000" Opacity="0.3"/>
    <DropShadowEffect x:Key="GlowBlue" BlurRadius="10" ShadowDepth="0"
                      Color="{StaticResource AccentBlue}" Opacity="0.4"/>

    <!-- ──────────────────────────────────────────────
         WINDOW STYLE
         ────────────────────────────────────────────── -->
    <Style x:Key="MetalWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource MetalDarkestBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ══════════════════════════════════════════════
         BUTTON STYLES
         ══════════════════════════════════════════════ -->

    <!-- ── MetalButton: Brushed steel button ── -->
    <Style x:Key="MetalButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MetalButtonBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource MetalButtonHoverBrush}"/>
                            <Setter Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLighter}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource MetalButtonPressedBrush}"/>
                            <Setter Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalBorder}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── AccentButton: Blue accent with metallic sheen ── -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentButtonBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource AccentButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource AccentButtonPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── DangerButton: Red variant ── -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DangerButtonBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource DangerButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background"
                                    Value="{StaticResource DangerButtonPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Window chrome buttons (minimize/maximize/close) ── -->
    <Style x:Key="ChromeButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeLightBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLight}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLighter}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentRed}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FFB62324"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         TEXTBOX STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalTextBox" TargetType="TextBox">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource MetalDarkest}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLighter}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource AccentBlueBrush}"/>
                            <Setter TargetName="Bd" Property="Effect"
                                    Value="{StaticResource GlowBlue}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         DATAGRID STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource MetalDarkBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource MetalDark}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="AlternatingRowBackground">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource MetalMedium}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RowHeight" Value="36"/>
        <Setter Property="ColumnHeaderHeight" Value="38"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- DataGrid column header -->
    <Style x:Key="MetalColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource MetalHeaderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeLightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid row -->
    <Style x:Key="MetalDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#FF1A2744" Opacity="0.6"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource AccentBlue}" Opacity="0.2"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid cell -->
    <Style x:Key="MetalDataGridCell" TargetType="DataGridCell">
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource ChromeWhiteBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════
         TABCONTROL STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
    </Style>

    <Style x:Key="MetalTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeLightBrush}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Content"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <!-- Active indicator line at bottom -->
                        <Border x:Name="Indicator"
                                Height="2"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                CornerRadius="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Content" Property="TextElement.Foreground"
                                    Value="{StaticResource ChromeWhiteBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Content" Property="TextElement.Foreground"
                                    Value="{StaticResource ChromeWhiteBrush}"/>
                            <Setter TargetName="Indicator" Property="Background"
                                    Value="{StaticResource AccentBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         COMBOBOX STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource MetalDarkestBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              ClickMode="Press"/>
                                <Path Grid.Column="1"
                                      Data="M 0,0 L 4,4 L 8,0"
                                      Stroke="{StaticResource ChromeLightBrush}"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource MetalMediumBrush}"
                                    BorderBrush="{StaticResource MetalBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,2,0,0"
                                    Padding="2"
                                    MaxHeight="300">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLighter}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource AccentBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MetalComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}" Opacity="0.15"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}" Opacity="0.25"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         CHECKBOX STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box" Width="18" Height="18"
                                CornerRadius="3"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource MetalBorderBrush}"
                                Background="{StaticResource MetalDarkestBrush}"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Check"
                                  Data="M 3,8 L 7,12 L 14,4"
                                  Stroke="White" StrokeThickness="2"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Margin="-1,-1,0,0"/>
                        </Border>
                        <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background"
                                    Value="{StaticResource AccentBlueBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush"
                                    Value="{StaticResource AccentBlueBrush}"/>
                            <Setter TargetName="Check" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalLighter}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         SCROLLBAR STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalScrollBarThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd" CornerRadius="4"
                            Background="{StaticResource MetalLighterBrush}"
                            Opacity="0.5"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="1.0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical ScrollBar -->
    <Style x:Key="MetalScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb Style="{StaticResource MetalScrollBarThumb}"/>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MetalScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ScrollViewer with metal scrollbars -->
    <Style x:Key="MetalScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Style="{StaticResource MetalScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Orientation="Horizontal"
                                   Style="{StaticResource MetalScrollBar}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         CARD / PANEL BORDER
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MetalCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="MetalPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MetalPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ══════════════════════════════════════════════
         STATUS LED INDICATORS
         ══════════════════════════════════════════════ -->
    <Style x:Key="StatusLed" TargetType="Ellipse">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Fill">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource MetalLighter}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                  Color="{StaticResource MetalLighter}" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusLedOnline" TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
        <Setter Property="Fill">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FF56D364" Offset="0"/>
                    <GradientStop Color="#FF3FB950" Offset="0.7"/>
                    <GradientStop Color="#FF238636" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                  Color="{StaticResource AccentGreen}" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusLedOffline" TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
        <Setter Property="Fill">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FF6E7681" Offset="0"/>
                    <GradientStop Color="#FF484F58" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusLedError" TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
        <Setter Property="Fill">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FFFF7B72" Offset="0"/>
                    <GradientStop Color="#FFF85149" Offset="0.7"/>
                    <GradientStop Color="#FFD73A49" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                  Color="{StaticResource AccentRed}" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusLedBooting" TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
        <Setter Property="Fill">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FFE3B341" Offset="0"/>
                    <GradientStop Color="#FFD29922" Offset="0.7"/>
                    <GradientStop Color="#FFBB8009" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                  Color="{StaticResource AccentAmber}" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         PROGRESSBAR STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource MetalDarkest}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="3"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <Border x:Name="PART_Track" CornerRadius="3">
                            <Border x:Name="PART_Indicator"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                                      Color="{StaticResource AccentBlue}"
                                                      Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         TOOLTIP STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalToolTip" TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource MetalMediumBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource CardShadow}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         CONTEXT MENU / MENU STYLE
         ══════════════════════════════════════════════ -->
    <Style x:Key="MetalContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource MetalMediumBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MetalMenuItem" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Grid.Column="0"
                                              ContentSource="Icon"
                                              Width="16" Height="16"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource MetalLighterBrush}"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}" Opacity="0.15"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu separator -->
    <Style x:Key="MetalMenuSeparator" TargetType="Separator">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="4,4"/>
        <Setter Property="Background" Value="{StaticResource MetalBorderBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         NAVIGATION SIDEBAR STYLES
         ══════════════════════════════════════════════ -->
    <Style x:Key="NavListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeLightBrush}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="6,1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- Left accent bar for selected state -->
                        <Border x:Name="AccentBar" Width="3"
                                HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="Transparent"
                                Margin="-6,4,0,4"/>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource MetalMedium}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground"
                                    Value="{StaticResource ChromeWhiteBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}" Opacity="0.12"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground"
                                    Value="{StaticResource ChromeWhiteBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="AccentBar" Property="Background"
                                    Value="{StaticResource AccentBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════
         LABEL / TEXT STYLES
         ══════════════════════════════════════════════ -->
    <Style x:Key="HeadingText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeWhiteBrush}"/>
    </Style>

    <Style x:Key="SubheadingText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeLightBrush}"/>
    </Style>

    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
    </Style>

    <!-- ══════════════════════════════════════════════
         GLOBAL IMPLICIT STYLES
         (apply dark theme to all unkeyed controls)
         ══════════════════════════════════════════════ -->

    <!-- Global Window background -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource MetalDarkestBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ChromeBrightBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
    </Style>

    <!-- Global ToolTip -->
    <Style TargetType="ToolTip" BasedOn="{StaticResource MetalToolTip}"/>

</ResourceDictionary>
