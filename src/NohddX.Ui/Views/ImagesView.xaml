<UserControl x:Class="NohddX.Ui.Views.ImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- ── Title ── -->
        <TextBlock DockPanel.Dock="Top" Text="BOOT IMAGES"
                   Style="{StaticResource HeadingText}"
                   Margin="0,0,0,16"/>

        <!-- ── Toolbar ── -->
        <Border DockPanel.Dock="Top" Style="{StaticResource MetalPanel}"
                Padding="12,8" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button Content="Upload Image" Style="{StaticResource AccentButton}"
                        Padding="12,6" Click="Upload_Click"/>
                <Button Content="Refresh" Style="{StaticResource MetalButton}"
                        Padding="12,6" Margin="8,0,0,0" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Image Cards Grid ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource MetalScrollViewer}">
            <ItemsControl x:Name="ImagesPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MetalCard}"
                                Width="280" Margin="0,0,16,16">
                            <DockPanel>
                                <!-- OS Icon + Name row -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                            Margin="0,0,0,12">
                                    <Viewbox Width="32" Height="32" Margin="0,0,12,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="{Binding OsIconColor}" Data="{Binding OsIconPath}"/>
                                        </Canvas>
                                    </Viewbox>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource ChromeWhiteBrush}"/>
                                        <TextBlock Foreground="{StaticResource MetalLighterBrush}"
                                                   FontSize="11">
                                            <Run Text="{Binding OsType, Mode=OneWay}"/>
                                            <Run Text="  "/>
                                            <Run Text="{Binding Version, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Details grid -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Size -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Size" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding SizeFormatted}"
                                                   Foreground="{StaticResource ChromeWhiteBrush}"
                                                   FontSize="14" FontWeight="Medium"/>
                                    </StackPanel>

                                    <!-- Usage count -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Clients" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding UsageCount}"
                                                   Foreground="{StaticResource ChromeWhiteBrush}"
                                                   FontSize="14" FontWeight="Medium"/>
                                    </StackPanel>

                                    <!-- Status -->
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="Status" Style="{StaticResource CaptionText}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Active">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Building">
                                                                <Setter Property="Fill" Value="{StaticResource AccentAmberBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{StaticResource ChromeBrightBrush}"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Action buttons -->
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Content="Snapshot" Style="{StaticResource MetalButton}"
                                            Padding="10,5" FontSize="12"/>
                                    <Button Content="Edit" Style="{StaticResource MetalButton}"
                                            Padding="10,5" FontSize="12" Margin="6,0,0,0"/>
                                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                                            Padding="10,5" FontSize="12" Margin="6,0,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
