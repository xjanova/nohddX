<UserControl x:Class="NohddX.Ui.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ LEFT COLUMN ══════════ -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="DASHBOARD"
                       Style="{StaticResource HeadingText}"
                       Margin="0,0,0,16"/>

            <!-- ── Stat Cards ── -->
            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,16">
                <!-- Total Clients -->
                <Border Style="{StaticResource MetalCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource AccentBlueBrush}"
                                          Data="M20,18c1.1,0 2,-0.9 2,-2V6c0,-1.1 -0.9,-2 -2,-2H4C2.9,4 2,4.9 2,6v10c0,1.1 0.9,2 2,2H0v2h24v-2H20z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Total Clients" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalClientsText" Text="1,024"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource ChromeWhiteBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Online Now -->
                <Border Style="{StaticResource MetalCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                                     Style="{StaticResource StatusLedOnline}"/>
                            <TextBlock Text="Online Now" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <TextBlock x:Name="OnlineNowText" Text="892"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Booting -->
                <Border Style="{StaticResource MetalCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                                     Style="{StaticResource StatusLedBooting}"/>
                            <TextBlock Text="Booting" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <TextBlock x:Name="BootingText" Text="12"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentAmberBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Boot Images -->
                <Border Style="{StaticResource MetalCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource AccentPurpleBrush}"
                                          Data="M2,20h20V4H2V20z M4,6h16v12H4V6z M6,18l3,-3.86 2.14,2.58 3,-3.86L18,18H6z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Boot Images" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <TextBlock x:Name="BootImagesText" Text="5"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource ChromeWhiteBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Storage Used -->
                <Border Style="{StaticResource MetalCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource AccentBlueBrush}"
                                          Data="M2,20h20v-4H2V20z M4,17h2v2H4V17z M2,4v4h20V4H2z M6,7H4V5h2V7z M2,14h20v-4H2V14z M4,11h2v2H4V11z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Storage Used" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <TextBlock x:Name="StorageUsedText" Text="2.1 TB"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource ChromeWhiteBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Network Throughput Chart ── -->
            <Border Grid.Row="2" Style="{StaticResource MetalCard}" Margin="0,0,0,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="NETWORK THROUGHPUT"
                               Style="{StaticResource SubheadingText}"
                               Margin="0,0,0,12"/>
                    <lvc:CartesianChart x:Name="ThroughputChart"/>
                </DockPanel>
            </Border>

            <!-- ── Recent Boot Events ── -->
            <Border Grid.Row="3" Style="{StaticResource MetalCard}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="RECENT BOOT EVENTS"
                               Style="{StaticResource SubheadingText}"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="BootEventsList"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,2"
                                        CornerRadius="4"
                                        Background="{StaticResource MetalDarkBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp}"
                                                   Style="{StaticResource MonoText}"
                                                   Foreground="{StaticResource MetalLighterBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MacAddress}"
                                                   Style="{StaticResource MonoText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Message}"
                                                   Foreground="{StaticResource ChromeLightBrush}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>

                                        <Ellipse Grid.Column="3"
                                                 Width="8" Height="8"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                            <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ══════════ RIGHT COLUMN: 3D Server Rack ══════════ -->
        <Border Grid.Column="1" Style="{StaticResource MetalCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="SERVER RACK"
                           Style="{StaticResource SubheadingText}"
                           Margin="0,0,0,8"/>

                <Viewport3D x:Name="RackViewport">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="3,2,5"
                                           LookDirection="-3,-1,-5"
                                           UpDirection="0,1,0"
                                           FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <Model3DGroup x:Name="RackModelGroup">
                                <AmbientLight Color="#333333"/>
                                <DirectionalLight Color="#AAAAAA" Direction="-1,-1,-1"/>
                                <DirectionalLight Color="#555555" Direction="1,0.5,0.5"/>
                                <!-- Server nodes added in code-behind -->
                            </Model3DGroup>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                </Viewport3D>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
