<UserControl x:Class="NohddX.Ui.Views.ClusterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- ── Title ── -->
        <TextBlock DockPanel.Dock="Top" Text="CLUSTER"
                   Style="{StaticResource HeadingText}"
                   Margin="0,0,0,16"/>

        <!-- ── Status Cards ── -->
        <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,16">
            <!-- Node Count -->
            <Border Style="{StaticResource MetalCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Nodes" Style="{StaticResource CaptionText}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="NodeCountText" Text="4"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource ChromeWhiteBrush}"/>
                </StackPanel>
            </Border>

            <!-- Leader -->
            <Border Style="{StaticResource MetalCard}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="Leader" Style="{StaticResource CaptionText}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="LeaderText" Text="node-01"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
            </Border>

            <!-- Total Clients -->
            <Border Style="{StaticResource MetalCard}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="Total Clients" Style="{StaticResource CaptionText}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="TotalClientsText" Text="1,024"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource ChromeWhiteBrush}"/>
                </StackPanel>
            </Border>

            <!-- Avg CPU / Mem -->
            <Border Style="{StaticResource MetalCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Avg Load" Style="{StaticResource CaptionText}"
                               Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CPU " FontSize="11"
                                   Foreground="{StaticResource MetalLighterBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="AvgCpuText" Text="42%"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource ChromeWhiteBrush}"
                                   Margin="0,0,12,0"/>
                        <TextBlock Text="MEM " FontSize="11"
                                   Foreground="{StaticResource MetalLighterBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="AvgMemText" Text="61%"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource ChromeWhiteBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ── Main content: 3D rack + Node grid ── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="160"/>
            </Grid.RowDefinitions>

            <!-- 3D Cluster Rack View -->
            <Border Grid.Row="0" Style="{StaticResource MetalCard}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="CLUSTER TOPOLOGY"
                               Style="{StaticResource SubheadingText}"
                               Margin="0,0,0,8"/>
                    <Viewport3D x:Name="ClusterViewport">
                        <Viewport3D.Camera>
                            <PerspectiveCamera Position="4,3,6"
                                               LookDirection="-4,-2,-6"
                                               UpDirection="0,1,0"
                                               FieldOfView="45"/>
                        </Viewport3D.Camera>
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup x:Name="ClusterModelGroup">
                                    <AmbientLight Color="#333333"/>
                                    <DirectionalLight Color="#AAAAAA" Direction="-1,-1,-1"/>
                                    <DirectionalLight Color="#555555" Direction="1,0.5,0.5"/>
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>
                    </Viewport3D>
                </DockPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        Margin="0,12">
                <Button Content="Join Node" Style="{StaticResource AccentButton}"
                        Padding="14,7"/>
                <Button Content="Leave Cluster" Style="{StaticResource DangerButton}"
                        Padding="14,7" Margin="8,0,0,0"/>
                <Button Content="Rebalance" Style="{StaticResource MetalButton}"
                        Padding="14,7" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Node Detail Grid -->
            <Border Grid.Row="2" Style="{StaticResource MetalCard}" Padding="0">
                <DataGrid x:Name="NodesGrid"
                          Style="{StaticResource MetalDataGrid}"
                          ColumnHeaderStyle="{StaticResource MetalColumnHeader}"
                          RowStyle="{StaticResource MetalDataGridRow}"
                          CellStyle="{StaticResource MetalDataGridCell}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <!-- Status LED -->
                        <DataGridTemplateColumn Header="" Width="36" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="10" Height="10"
                                             HorizontalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Health}" Value="Healthy">
                                                        <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Health}" Value="Warning">
                                                        <Setter Property="Fill" Value="{StaticResource AccentAmberBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Health}" Value="Error">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Node Name" Binding="{Binding Name}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                        <DataGridTextColumn Header="Clients" Binding="{Binding ClientCount}" Width="80"/>

                        <DataGridTemplateColumn Header="CPU %" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CpuPercent, StringFormat={}{0}%}"
                                                   Width="35" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource ChromeLightBrush}"
                                                   FontSize="11"/>
                                        <ProgressBar Value="{Binding CpuPercent}"
                                                     Maximum="100"
                                                     Style="{StaticResource MetalProgressBar}"
                                                     Height="4" Margin="0,0,6,0"
                                                     VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Memory %" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding MemPercent, StringFormat={}{0}%}"
                                                   Width="35" TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource ChromeLightBrush}"
                                                   FontSize="11"/>
                                        <ProgressBar Value="{Binding MemPercent}"
                                                     Maximum="100"
                                                     Style="{StaticResource MetalProgressBar}"
                                                     Height="4" Margin="0,0,6,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{StaticResource AccentPurpleBrush}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Status" Binding="{Binding Health}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
