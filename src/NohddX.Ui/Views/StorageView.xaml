<UserControl x:Class="NohddX.Ui.Views.StorageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- ── Title ── -->
        <TextBlock DockPanel.Dock="Top" Text="STORAGE"
                   Style="{StaticResource HeadingText}"
                   Margin="0,0,0,16"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource MetalScrollViewer}">
            <StackPanel>
                <!-- ══════════ Storage Pools ══════════ -->
                <TextBlock Text="STORAGE POOLS"
                           Style="{StaticResource SubheadingText}"
                           Margin="0,0,0,12"/>

                <ItemsControl x:Name="StoragePoolsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MetalCard}"
                                    Width="320" Margin="0,0,16,16">
                                <StackPanel>
                                    <!-- Pool header -->
                                    <DockPanel Margin="0,0,0,12">
                                        <Viewbox DockPanel.Dock="Left"
                                                 Width="20" Height="20" Margin="0,0,10,0">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="{StaticResource AccentBlueBrush}"
                                                      Data="M2,20h20v-4H2V20z M4,17h2v2H4V17z M2,4v4h20V4H2z M6,7H4V5h2V7z M2,14h20v-4H2V14z M4,11h2v2H4V11z"/>
                                            </Canvas>
                                        </Viewbox>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ChromeWhiteBrush}"/>
                                            <TextBlock Foreground="{StaticResource MetalLighterBrush}"
                                                       FontSize="11">
                                                <Run Text="{Binding RaidLevel, Mode=OneWay}"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding HealthStatus, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Usage bar -->
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock DockPanel.Dock="Right"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MetalLighterBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0">
                                            <Run Text="{Binding UsedFormatted, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding TotalFormatted, Mode=OneWay}"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding UsagePercent}"
                                                     Maximum="100"
                                                     Height="8"
                                                     VerticalAlignment="Center">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource MetalProgressBar}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHighUsage}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCriticalUsage}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </DockPanel>

                                    <!-- Free space -->
                                    <TextBlock FontSize="11" Margin="0,4,0,0"
                                               Foreground="{StaticResource ChromeLightBrush}">
                                        <Run Text="{Binding FreeFormatted, Mode=OneWay}"/>
                                        <Run Text=" free ("/>
                                        <Run Text="{Binding UsagePercent, Mode=OneWay, StringFormat={}{0:F0}}"/>
                                        <Run Text="% used)"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ══════════ Disk Health ══════════ -->
                <TextBlock Text="DISK HEALTH"
                           Style="{StaticResource SubheadingText}"
                           Margin="0,8,0,12"/>

                <Border Style="{StaticResource MetalCard}" Padding="0" Margin="0,0,0,16">
                    <DataGrid x:Name="DiskHealthGrid"
                              Style="{StaticResource MetalDataGrid}"
                              ColumnHeaderStyle="{StaticResource MetalColumnHeader}"
                              RowStyle="{StaticResource MetalDataGridRow}"
                              CellStyle="{StaticResource MetalDataGridCell}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <!-- Health LED -->
                            <DataGridTemplateColumn Header="" Width="36" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="10" Height="10"
                                                 HorizontalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusLed}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Health}" Value="Good">
                                                            <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Health}" Value="Warning">
                                                            <Setter Property="Fill" Value="{StaticResource AccentAmberBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Health}" Value="Failing">
                                                            <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="200"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="100"/>
                            <DataGridTextColumn Header="Temp" Binding="{Binding Temperature}" Width="80"/>
                            <DataGridTextColumn Header="Pool" Binding="{Binding Pool}" Width="120"/>
                            <DataGridTextColumn Header="Health" Binding="{Binding Health}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- ══════════ Image Storage Breakdown ══════════ -->
                <TextBlock Text="IMAGE STORAGE BREAKDOWN"
                           Style="{StaticResource SubheadingText}"
                           Margin="0,0,0,12"/>

                <Border Style="{StaticResource MetalCard}" Padding="0">
                    <DataGrid x:Name="ImageStorageGrid"
                              Style="{StaticResource MetalDataGrid}"
                              ColumnHeaderStyle="{StaticResource MetalColumnHeader}"
                              RowStyle="{StaticResource MetalDataGridRow}"
                              CellStyle="{StaticResource MetalDataGridCell}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Image" Binding="{Binding ImageName}" Width="180"/>
                            <DataGridTextColumn Header="Base Size" Binding="{Binding BaseSize}" Width="120"/>
                            <DataGridTextColumn Header="Overlays" Binding="{Binding OverlaySize}" Width="120"/>
                            <DataGridTextColumn Header="Snapshots" Binding="{Binding SnapshotSize}" Width="120"/>

                            <DataGridTemplateColumn Header="Total" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding TotalSize}"
                                                       Width="60" TextAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ChromeWhiteBrush}"
                                                       FontSize="12"/>
                                            <ProgressBar Value="{Binding SizePercent}"
                                                         Maximum="100"
                                                         Style="{StaticResource MetalProgressBar}"
                                                         Height="4" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
