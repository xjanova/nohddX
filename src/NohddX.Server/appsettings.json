{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "NohddxDb": "Data Source=nohddx.db"
  },
  "Database": {
    "Provider": "sqlite"
  },
  "NohddX": {
    "StorageBasePath": "./storage",
    "BaseImagesPath": "./storage/bases",
    "OverlaysPath": "./storage/overlays",
    "SnapshotsPath": "./storage/snapshots",
    "DhcpProxy": {
      "Enabled": true,
      "Port": 4011
    },
    "Iscsi": {
      "Port": 3260
    },
    "Tftp": {
      "Enabled": true,
      "Port": 69,
      "IpxeBinaryPath": "../../tools/ipxe"
    },
    "Cluster": {
      "Enabled": false
    },
    "Discovery": {
      "Enabled": true,
      "Port": 4012,
      "AnnouncedPort": 8080
    },
    "Security": {
      "AuthEnabled": true,
      "AdminApiKey": "",
      "AgentTokenSecret": "",
      "AgentTokenLifetimeHours": 24,
      "BootstrapToken": "",
      "AllowAnonymousAdminInDev": true,
      "AgentRegisterRatePerMinute": 30,
      "AdminRatePerMinute": 600,
      "MaxAgentBodyBytes": 262144,
      "AuditLogEnabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  }
}
