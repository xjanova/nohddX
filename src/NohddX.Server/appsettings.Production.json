{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NohddX": {
    "Security": {
      "AuthEnabled": true,
      "AdminApiKey": "${NOHDDX_ADMIN_API_KEY}",
      "AgentTokenSecret": "${NOHDDX_AGENT_TOKEN_SECRET}",
      "BootstrapToken": "${NOHDDX_BOOTSTRAP_TOKEN}",
      "AllowAnonymousAdminInDev": false,
      "AuditLogEnabled": true
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      },
      "Https": {
        "Url": "https://0.0.0.0:8443",
        "Certificate": {
          "Path": "/etc/nohddx/cert.pfx",
          "Password": "${NOHDDX_CERT_PASSWORD}"
        }
      }
    }
  }
}
